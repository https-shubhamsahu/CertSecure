
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user in the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "firstName": {
          "type": "string",
          "description": "First name of the user."
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the user."
        },
        "role": {
          "type": "string",
          "description": "Role of the user (Employer, University, Student, Admin)."
        }
      },
      "required": [
        "id",
        "email",
        "firstName",
        "lastName",
        "role"
      ]
    },
    "Certificate": {
      "title": "Certificate",
      "type": "object",
      "description": "Represents a certificate uploaded to the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the certificate."
        },
        "userId": {
          "type": "string",
          "description": "Reference to User. (Relationship: User 1:N Certificate)"
        },
        "fileName": {
          "type": "string",
          "description": "Name of the certificate file."
        },
        "uploadDate": {
          "type": "string",
          "description": "Date and time when the certificate was uploaded.",
          "format": "date-time"
        },
        "verificationStatus": {
          "type": "string",
          "description": "The certificate verification status."
        },
        "verificationResult": {
          "type": "string",
          "description": "The result of the certificate verification."
        }
      },
      "required": [
        "id",
        "userId",
        "fileName",
        "uploadDate",
        "verificationStatus",
        "verificationResult"
      ]
    },
    "SystemStats": {
      "title": "SystemStats",
      "type": "object",
      "description": "Real-time statistics for the entire system.",
      "properties": {
        "totalUniversities": { "type": "number" },
        "certificatesVerifiedToday": { "type": "number" },
        "fraudDetected24h": { "type": "number" },
        "activeVerifications": { "type": "number" },
        "systemUptime": { "type": "number", "description": "Percentage" }
      }
    },
    "University": {
      "title": "University",
      "type": "object",
      "description": "Represents a university or institution.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "state": { "type": "string" },
        "type": { "type": "string", "enum": ["Government", "Private", "Deemed", "Foreign"] },
        "integrationStatus": { "type": "string", "enum": ["Active", "Pending", "Error"] }
      }
    },
    "VerificationActivity": {
      "title": "VerificationActivity",
      "type": "object",
      "description": "Represents a single verification event.",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "universityName": { "type": "string" },
        "state": { "type": "string" },
        "status": { "type": "string", "enum": ["Verified", "Fraudulent", "Pending"] }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": {
      "/users/{userId}": {
        "schema": { "$ref": "#/entities/User" },
        "description": "Stores user profile information. Each document is keyed by the user's unique ID."
      },
      "/users/{userId}/certificates/{certificateId}": {
        "schema": { "$ref": "#/entities/Certificate" },
        "description": "Stores certificate information for each user."
      },
      "/roles_admin/{userId}": {
        "schema": { "$ref": "#/entities/User" },
        "description": "Collection to store admin user roles. Existence of a document with the user's ID grants admin privileges."
      },
      "/roles_university/{userId}": {
        "schema": { "$ref": "#/entities/User" },
        "description": "Collection to store university user roles. Existence of a document with the user's ID grants university privileges."
      },
      "/roles_employer/{userId}": {
        "schema": { "$ref": "#/entities/User" },
        "description": "Collection to store employer user roles. Existence of a document with the user's ID grants employer privileges."
      },
      "/system/stats": {
        "schema": { "$ref": "#/entities/SystemStats" },
        "description": "Singleton document for system-wide statistics."
      },
      "/universities/{universityId}": {
        "schema": { "$ref": "#/entities/University" },
        "description": "Stores information about registered universities."
      },
      "/verifications/{verificationId}": {
        "schema": { "$ref": "#/entities/VerificationActivity" },
        "description": "Log of all verification activities."
      }
    }
  }
}
