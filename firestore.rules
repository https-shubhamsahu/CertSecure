/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile data, accessible only to the user themselves.
 * - /users/{userId}/certificates/{certificateId}: Stores user-specific certificates, accessible only to the user.
 * - /roles_admin/{userId}: Presence indicates admin role, writable only by admins (not implemented in this prototype).
 * - /roles_university/{userId}: Presence indicates university role, writable only by admins (not implemented in this prototype).
 * - /roles_employer/{userId}: Presence indicates employer role, writable only by admins (not implemented in this prototype).
 *
 * Key Security Decisions:
 * - User data and certificates are strictly owned by the user; no cross-user access is permitted.
 * - Role assignment (admin, university, employer) is not yet secured and is open for prototyping convenience. In a production environment, role assignment should be restricted to privileged users or services.
 * - Data schema validation is disabled for rapid prototyping, but should be added in later iterations to enforce data integrity.
 *
 * Denormalization for Authorization:
 * - The rules rely on the `request.auth.uid` to match the `userId` in the path for ownership checks, avoiding the need to read the user document itself.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile.
     * @deny (create) User with ID 'user456' cannot create a profile for 'user123'.
     * @allow (get) User with ID 'user123' can read their profile.
     * @deny (get) User with ID 'user456' cannot read the profile of 'user123'.
     * @allow (update) User with ID 'user123' can update their profile.
     * @deny (update) User with ID 'user456' cannot update the profile of 'user123'.
     * @allow (delete) User with ID 'user123' can delete their profile.
     * @deny (delete) User with ID 'user456' cannot delete the profile of 'user123'.
     * @principle Enforces user-ownership for read/write access to user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Listing users is not permitted

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && resource.data.id == userId;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Controls access to user-specific certificates.
     * @path /users/{userId}/certificates/{certificateId}
     * @allow (create) User with ID 'user123' can create a certificate.
     * @deny (create) User with ID 'user456' cannot create a certificate for 'user123'.
     * @allow (get) User with ID 'user123' can read their certificate.
     * @deny (get) User with ID 'user456' cannot read the certificate of 'user123'.
     * @allow (update) User with ID 'user123' can update their certificate.
     * @deny (update) User with ID 'user456' cannot update the certificate of 'user123'.
     * @allow (delete) User with ID 'user123' can delete their certificate.
     * @deny (delete) User with ID 'user456' cannot delete the certificate of 'user123'.
     * @principle Enforces user-ownership for read/write access to certificates.
     */
    match /users/{userId}/certificates/{certificateId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isOwner(userId) && resource.data.userId == userId && resource != null;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Controls access to admin role assignments.
     * @path /roles_admin/{userId}
     * @allow (create) Any signed in user can create their role assignment, but should be restricted to privileged users or services.
     * @deny (create)  Unsigned user cannot create a role assignment.
     * @allow (get) Any signed in user can get their role assignment.
     * @deny (get) Unsigned user cannot get a role assignment.
     * @allow (update) Any signed in user can update their role assignment, but should be restricted to privileged users or services.
     * @deny (update) Unsigned user cannot update a role assignment.
     * @allow (delete) Any signed in user can delete their role assignment, but should be restricted to privileged users or services.
     * @deny (delete) Unsigned user cannot delete a role assignment.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if false;

      // CRITICAL: In a production environment, role assignment should be restricted to privileged users or services.
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Controls access to university role assignments.
     * @path /roles_university/{userId}
     * @allow (create) Any signed in user can create their role assignment, but should be restricted to privileged users or services.
     * @deny (create)  Unsigned user cannot create a role assignment.
     * @allow (get) Any signed in user can get their role assignment.
     * @deny (get) Unsigned user cannot get a role assignment.
     * @allow (update) Any signed in user can update their role assignment, but should be restricted to privileged users or services.
     * @deny (update) Unsigned user cannot update a role assignment.
     * @allow (delete) Any signed in user can delete their role assignment, but should be restricted to privileged users or services.
     * @deny (delete) Unsigned user cannot delete a role assignment.
     */
    match /roles_university/{userId} {
      allow get: if isSignedIn();
      allow list: if false;

      // CRITICAL: In a production environment, role assignment should be restricted to privileged users or services.
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Controls access to employer role assignments.
     * @path /roles_employer/{userId}
     * @allow (create) Any signed in user can create their role assignment, but should be restricted to privileged users or services.
     * @deny (create)  Unsigned user cannot create a role assignment.
     * @allow (get) Any signed in user can get their role assignment.
     * @deny (get) Unsigned user cannot get a role assignment.
     * @allow (update) Any signed in user can update their role assignment, but should be restricted to privileged users or services.
     * @deny (update) Unsigned user cannot update a role assignment.
     * @allow (delete) Any signed in user can delete their role assignment, but should be restricted to privileged users or services.
     * @deny (delete) Unsigned user cannot delete a role assignment.
     */
    match /roles_employer/{userId} {
      allow get: if isSignedIn();
      allow list: if false;

      // CRITICAL: In a production environment, role assignment should be restricted to privileged users or services.
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }
  }
}